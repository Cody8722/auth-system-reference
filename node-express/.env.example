# MongoDB 連線字串（必填）
# 與排班系統、會計系統使用同一個 MongoDB Atlas cluster
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/

# 伺服器埠號（預設 3001，避免與排班系統 3000 衝突）
PORT=3001

# JWT 密鑰（必須與排班系統、會計系統使用同一個值，token 才能互通）
JWT_SECRET=

# CORS（選填，未設定則允許全部）
CORS_ORIGIN=

# Gmail SMTP（忘記密碼功能）
# 設定步驟：啟用兩步驟驗證 → 生成「應用程式密碼」（16 位）
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=
SMTP_FROM_NAME=Auth 參考系統
